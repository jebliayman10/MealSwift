# ─── Database ───────────────────────────────────────────────────────────────
# DEV  : local SQLite (default below) — no setup needed.
# PROD : a Postgres connection string (Vercel Postgres / Neon / Supabase).
#        Also change `provider` in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# ─── Auth.js (NextAuth) ─────────────────────────────────────────────────────
# Generate a fresh value: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# ─── Google OAuth ───────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Resend (email magic links) ─────────────────────────────────────────────
# Free API key + verified domain at https://resend.com
RESEND_API_KEY=
EMAIL_FROM="MealSwift <onboarding@resend.dev>"
