{
  "name": "mealswift",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "verify": "npm run typecheck && npm run lint && node scripts/verify-db.mjs && npm run build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "22.9.0",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "prisma": "^6.19.3",
    "typescript": "5.6.3"
  }
}
